[Unit]
Description=Bracket Builder
After=network.target

[Service]
Type=simple
User=bracket
Group=bracket
WorkingDirectory=/opt/bracket-builder
ExecStart=/usr/bin/node server.js
Restart=on-failure
RestartSec=5

Environment=NODE_ENV=production
Environment=PORT=3000

StandardOutput=journal
StandardError=journal
SyslogIdentifier=bracket-builder

[Install]
WantedBy=multi-user.target
